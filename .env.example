NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
LOG_SERVICE_NAME=user-service

# Postgres (Neon pooled endpoint in prod; local docker-compose in dev)
USER_DB_URL=postgresql://user:pass@localhost:5433/userdb?schema=public

# User JWT — SAME value as auth-service's AUTH_JWT_SECRET (HS256)
USER_JWT_SECRET=replace-me-min-32-chars-development-only

# Service JWT — SAME value as gateway's SERVICE_JWT_SECRET (HS256)
# MUST be distinct from USER_JWT_SECRET
USER_SERVICE_JWT_SECRET=replace-me-distinct-min-32-chars-dev

# RabbitMQ (local broker container in dev; CloudAMQP in prod)
RABBITMQ_URL=amqp://guest:guest@localhost:5672
